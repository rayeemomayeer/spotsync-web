# Copy to .env.local for local development.
NEXT_PUBLIC_API_BASE_URL=http://localhost:4000/api/v1
NEXT_PUBLIC_BFF_URL=http://localhost:4000
NEXT_PUBLIC_BFF_PROXY_ORIGIN=http://localhost:4000
# Go API origin for Observe / warm probes (required in prod when API base is BFF)
NEXT_PUBLIC_GO_API_URL=http://localhost:8081

# Optional observability
NEXT_PUBLIC_SENTRY_DSN=
# Grafana share/embed URL (Observe dashboards)
NEXT_PUBLIC_GRAFANA_URL=
# Optional public docs link for /metrics
NEXT_PUBLIC_METRICS_URL=

# Feature flags (comma-separated): stripe_billing, driver_payments, org_search, demo_console, demo_mode
NEXT_PUBLIC_FEATURE_FLAGS=stripe_billing,driver_payments

# Stripe TEST publishable key optional (hosted Checkout does not need it in the browser)
# NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...

# Demo / showcase (off by default locally)
NEXT_PUBLIC_DEMO_MODE=false
NEXT_PUBLIC_DEMO_GHOST_GRID=false
# Platform saas_admin quick-login (defaults: admin@spotsync.com / AdminPass123!)
# NEXT_PUBLIC_DEMO_ADMIN_EMAIL=admin@spotsync.com
# NEXT_PUBLIC_DEMO_ADMIN_PASSWORD=AdminPass123!

# Optional Google OAuth (BFF)
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
# PLAYWRIGHT_BASE_URL=https://spotsync-nu.vercel.app
